generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ANALYST
}

enum Priority {
  Low
  Medium
  High
  Critical
}

model LOB {
  id        String   @id @default(cuid())
  name      String   @unique
  headName  String?
  headEmail String?
  headPhone String? // E.164 format, used to build the wa.me share link
  createdAt DateTime @default(now())

  users        User[]
  requirements Requirement[]
  deliveries   Delivery[]
  delayUpdates DelayUpdate[]
  reports      DailyReport[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ANALYST)
  lobId        String?
  lob          LOB?     @relation(fields: [lobId], references: [id])
  createdAt    DateTime @default(now())

  requirements Requirement[]
  deliveries   Delivery[]
  delayUpdates DelayUpdate[]
}

model Requirement {
  id           String   @id @default(cuid())
  date         String // YYYY-MM-DD, the business day this entry belongs to
  description  String
  receivedFrom String? // who/which team the requirement was received from
  receivedDate String? // YYYY-MM-DD, when the requirement was received
  category     String   @default("Development") // Change Request | Production Movement | Maintenance | Development | Bug Fix
  priority     Priority @default(Medium)
  module       String?
  lobId        String
  lob          LOB      @relation(fields: [lobId], references: [id])
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  @@index([lobId, date])
}

model Delivery {
  id           String   @id @default(cuid())
  date         String
  description  String
  remarks      String?
  category     String   @default("Development") // Change Request | Production Movement | Maintenance | Development | Bug Fix
  receivedFrom String? // who/which team the underlying requirement was received from
  receivedDate String? // YYYY-MM-DD, when the requirement was received
  closedDate   String? // YYYY-MM-DD, when the delivery actually happened/closed
  module       String?
  lobId        String
  lob          LOB      @relation(fields: [lobId], references: [id])
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  @@index([lobId, date])
}

// Tracks whether an already-scheduled deliverable is on track, WIP, or has
// slipped — typically because an urgent same-day requirement bumped it.
// status is a free-form string (not a DB enum) so it can hold multi-word
// values like "At Risk", mirroring how Delivery.category is modeled below.
model DelayUpdate {
  id              String   @id @default(cuid())
  date            String // YYYY-MM-DD, the business day this update was logged
  module          String?
  deliverable     String // name of the task/deliverable this update is about
  category        String   @default("Development") // Change Request | Production Movement | Maintenance | Development | Bug Fix
  receivedFrom    String? // who/which team the underlying requirement was received from
  receivedDate    String? // YYYY-MM-DD, when the requirement was received
  originalDueDate String? // YYYY-MM-DD, the originally committed date
  revisedDueDate  String? // YYYY-MM-DD, the new expected date (if delayed)
  approvalTaken   Boolean  @default(false) // whether approval for the revised date was taken
  approvedBy      String? // who approved the revised date, if approvalTaken
  approvedDate    String? // YYYY-MM-DD, when the approval was taken, if approvalTaken
  status          String   @default("WIP") // WIP | On Track | Delayed | At Risk | Completed
  reason          String? // why it slipped, e.g. the urgent requirement that bumped it
  lobId           String
  lob             LOB      @relation(fields: [lobId], references: [id])
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())

  @@index([lobId, date])
}

// One cached/generated snapshot per LOB per day — regenerated on demand,
// holds the rendered PNG path (WhatsApp preview) and PDF path (downloadable/
// emailed document) plus the wa.me share link built from them.
model DailyReport {
  id           String   @id @default(cuid())
  date         String
  lobId        String
  lob          LOB      @relation(fields: [lobId], references: [id])
  imagePath    String
  imageUrl     String
  pdfPath      String?
  pdfUrl       String?
  shareLink    String
  requirements Int
  deliveries   Int
  modules      Int
  bugFixes     Int
  features     Int
  delayFlags   Int      @default(0)
  generatedAt  DateTime @default(now())

  @@unique([lobId, date])
}